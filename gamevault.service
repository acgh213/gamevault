[Unit]
Description=GameVault
After=network.target

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/gamevault
Environment=HOME=/home/exedev
Environment=VIRTUAL_ENV=/home/exedev/gamevault/venv
Environment=PATH=/home/exedev/gamevault/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/exedev/gamevault/venv/bin/python -m flask --app app run --host 0.0.0.0 --port 8891
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
